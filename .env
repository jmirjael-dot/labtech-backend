# =========================================================
# LABTECH MINERO — VARIABLES DE ENTORNO
# Copiar a .env y completar con valores reales.
# NUNCA subir el archivo .env real a git.
# =========================================================

# ---- Servidor ----
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
CLIENT_APP_URL=http://localhost:8080
DASHBOARD_URL=http://localhost:8081
# Orígenes permitidos por CORS, separados por coma
CORS_ORIGINS=http://localhost:8080,http://localhost:8081

# ---- Base de datos (PostgreSQL) ----
DATABASE_URL="postgresql://labtech_user:labtech_pass@localhost:5432/labtech_minero?schema=public"

# ---- JWT ----
JWT_ACCESS_SECRET=cambia-este-valor-por-un-secreto-largo-y-aleatorio
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia-este-otro-valor-tambien-largo-y-aleatorio
JWT_REFRESH_EXPIRES_IN=30d

# ---- bcrypt ----
BCRYPT_SALT_ROUNDS=12

# ---- Almacenamiento de archivos ----
# STORAGE_DRIVER = "local" | "s3"
STORAGE_DRIVER=local
LOCAL_UPLOADS_DIR=uploads

# AWS S3 (solo si STORAGE_DRIVER=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=labtech-minero-files

# ---- Pasarelas de pago ----
# Culqi (tarjetas)
CULQI_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
CULQI_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Yape Business (API de cobros)
YAPE_BUSINESS_API_KEY=
YAPE_BUSINESS_MERCHANT_ID=

# Transferencia BCP (datos mostrados al cliente, no requiere API)
BCP_ACCOUNT_NUMBER=191-2547896-0-01
BCP_CCI=002-191-002547896001-45
BCP_ACCOUNT_HOLDER="LabTech Minero SAC"

# ---- Email (Resend o Nodemailer/SMTP) ----
EMAIL_DRIVER=resend
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM="LabTech Minero <notificaciones@labtechminero.pe>"

# SMTP (solo si EMAIL_DRIVER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---- Facturación electrónica ----
INVOICE_SERIES_BOLETA=B001
INVOICE_SERIES_FACTURA=F001
INVOICE_IGV_PERCENT=18

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
DATABASE_URL="postgresql://labtech_user:labtech_pass@localhost:5432/labtech_minero?schema=public"
